# 生产环境（prod profile）所需环境变量示例。
# 复制为 .env 并填入真实值后，由部署环境导出（export）或注入容器；切勿提交真实密钥。
# 对应 src/main/resources/application-prod.properties 中的 ${...} 占位。
# docker compose 也会读取本目录的 .env：复用其中的 DB_USERNAME/DB_PASSWORD/CENTRAL_KEY_PAIR_*，
# 并自动将应用的 DB_URL 指向 compose 内的 postgres 服务（无需手改下面的 DB_URL）。

# 数据库连接
DB_URL=jdbc:postgresql://localhost:5432/nmsci
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# 中心密钥对（Base64）：pubkey 为 33 字节压缩公钥，prikey 为 32 字节私钥
CENTRAL_KEY_PAIR_PUBKEY=CHANGE_ME_base64_compressed_public_key
CENTRAL_KEY_PAIR_PRIKEY=CHANGE_ME_base64_private_key
